generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id            Int            @id @default(autoincrement())
  rol           String         @unique
  descripcion    String?
  usuarios      Usuario[]
}

model Clinica {
  id               Int            @id @default(autoincrement())
  nombre           String
  razon_social     String?
  rfc              String?
  telefono         String?
  correo_contacto  String?
  direccion        String?
  estado           String         @default("activa")
  usuarios         Usuario[]
  profesionales    Profesional[]
  tutores          Tutor[]
  pacientes        Paciente[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Usuario {
  id                   Int            @id @default(autoincrement())
  correo               String         @unique
  password_hash        String
  estado               String         @default("activo")
  must_change_password Boolean        @default(false)
  mfaEnabled           Boolean        @default(false)

  id_rol               Int
  rol                  Role           @relation(fields: [id_rol], references: [id])

  id_clinica           Int?
  clinica              Clinica?       @relation(fields: [id_clinica], references: [id])

  profesional          Profesional?
  tutor                Tutor?
  refreshTokens        RefreshToken[]
  mfaChallenges        MfaChallenge[]
  tutorPacientes       TutorPaciente[]
  archivosSubidos      Archivo[]

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model Profesional {
  id             Int       @id @default(autoincrement())
  id_usuario     Int       @unique
  usuario        Usuario   @relation(fields: [id_usuario], references: [id])

  id_clinica     Int
  clinica        Clinica   @relation(fields: [id_clinica], references: [id])

  nombre         String
  ap_paterno     String
  ap_materno     String?
  telefono       String?
  especialidad   String
  organizacion   String?

  foto_url       String?
  foto_public_id String?

  encuentros     Encuentro[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([id_clinica])
  @@index([especialidad])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  usuario   Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model MfaChallenge {
  id             String    @id @default(cuid())
  userId         Int
  usuario        Usuario   @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash       String
  expiresAt      DateTime
  used           Boolean   @default(false)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId])
}

// ─── Núcleo clínico ───────────────────────────────────────────────────────────

model Paciente {
  id                      Int             @id @default(autoincrement())

  id_clinica              Int
  clinica                 Clinica         @relation(fields: [id_clinica], references: [id])

  nombre                  String
  ap_paterno              String
  ap_materno              String?
  fecha_nacimiento        DateTime        @db.Date
  sexo                    String          // M, F, Otro
  escolaridad             String?

  // Datos clínicos
  diagnostico_presuntivo  String?
  antecedentes_relevantes String?
  notas_generales         String?

  estado                  String          @default("activo") // activo, inactivo

  tutores                 TutorPaciente[]
  encuentros              Encuentro[]
  archivos                Archivo[]

  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([id_clinica])
  @@index([estado])
}

/// Tabla puente Paciente ↔ Usuario (rol=tutor).
/// Preparada para migrar a una entidad Tutor independiente en el futuro.
model TutorPaciente {
  id           Int      @id @default(autoincrement())
  id_paciente  Int
  paciente     Paciente @relation(fields: [id_paciente], references: [id], onDelete: Cascade)
  id_usuario   Int
  usuario      Usuario  @relation(fields: [id_usuario], references: [id])
  parentesco   String   // madre, padre, tutor legal, etc.
  es_principal Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([id_paciente, id_usuario])
  @@index([id_paciente])
}

// ─── Perfil de Tutor (1:1 con Usuario) ───────────────────────────────────────
/// Datos personales del tutor. La cuenta de acceso es Usuario (role=tutor).
/// Sigue el mismo patrón que Profesional.
model Tutor {
  id           Int      @id @default(autoincrement())

  id_usuario   Int      @unique
  usuario      Usuario  @relation(fields: [id_usuario], references: [id])

  id_clinica   Int
  clinica      Clinica  @relation(fields: [id_clinica], references: [id])

  nombre       String
  ap_paterno   String
  ap_materno   String?
  telefono     String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([id_clinica])
}

// ─── Audit / Logs ─────────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  userEmail  String?
  userRole   String?
  action     String
  entity     String?
  entityId   Int?
  detail     String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

// ─── Análisis / Multimedia ────────────────────────────────────────────────────

model Encuentro {
  id               Int         @id @default(autoincrement())
  id_paciente      Int
  paciente         Paciente    @relation(fields: [id_paciente], references: [id])
  id_profesional   Int
  profesional      Profesional @relation(fields: [id_profesional], references: [id])

  tipo_encuentro   String
  fecha            DateTime    @db.Date
  motivo           String
  resumen          String?
  estado           String      @default("completado")

  archivos         Archivo[]

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([id_paciente])
  @@index([id_profesional])
}

model Archivo {
  id               Int         @id @default(autoincrement())
  id_paciente      Int
  paciente         Paciente    @relation(fields: [id_paciente], references: [id])
  id_encuentro     Int?
  encuentro        Encuentro?  @relation(fields: [id_encuentro], references: [id])

  nombre_archivo   String
  tipo_mime        String
  tamano_bytes     Int
  url_placeholder  String?
  descripcion      String?
  
  subido_por_id    Int
  usuario          Usuario     @relation(fields: [subido_por_id], references: [id])

  analisis         AnalisisIA?

  createdAt        DateTime    @default(now())

  @@index([id_paciente])
  @@index([id_encuentro])
  @@index([subido_por_id])
}

model AnalisisIA {
  id               Int      @id @default(autoincrement())
  id_archivo       Int      @unique
  archivo          Archivo  @relation(fields: [id_archivo], references: [id])

  estado           String   @default("completado")
  score            Float?
  clasificacion    String?
  confianza        Float?
  
  modelo           String?  @default("mock")
  modelo_version   String?  @default("sim-v1")
  error_msg        String?

  observaciones    String?  @db.Text

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}