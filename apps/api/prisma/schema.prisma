generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          Int      @id @default(autoincrement())
  rol         String   @unique
  descripcion String?
  usuarios    Usuario[]
}

model Clinica {
  id               Int      @id @default(autoincrement())
  nombre           String
  razon_social     String?
  rfc              String?
  telefono         String?
  correo_contacto  String?
  direccion        String?
  estado           String   @default("activa") // activa, suspendida
  usuarios         Usuario[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Usuario {
  id            Int      @id @default(autoincrement())
  correo        String   @unique
  password_hash String
  estado        String   @default("activo") // activo, suspendido, pendiente

  id_rol        Int
  rol           Role     @relation(fields: [id_rol], references: [id])

  id_clinica    Int?
  clinica       Clinica? @relation(fields: [id_clinica], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}